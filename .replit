modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && PORT=8080 npm run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && PORT=5000 npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[userenv]

[userenv.shared]
NODE_ENV = "development"
FRONTEND_URL = "https://1435371d-efd4-407f-8c3d-818e01deb594-00-n9gigeobykra.pike.replit.dev"
LOG_LEVEL = "info"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && PORT=5000 node dist/index.js"]
build = ["bash", "-c", "npm run build:backend && npm run build:frontend"]
